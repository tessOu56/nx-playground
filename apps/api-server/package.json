{
  "name": "@nx-playground/api-server",
  "version": "0.1.0",
  "description": "NestJS API Server for NX Playground",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "gen:contract-types": "openapi-typescript ../../libs/api-client/specs/catalog.openapi.yaml -o src/modules/catalog/contract/catalog.contract.ts"
  }
}
